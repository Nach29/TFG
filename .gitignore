# ========================
# Terraform
# ========================

# Local .terraform directories (provider cache, plugins)
**/.terraform/

# Terraform lock file (keep this if you want reproducible provider versions)
# .terraform.lock.hcl

# State files — NEVER commit state (may contain secrets)
*.tfstate
*.tfstate.backup
*.tfstate.d/

# Crash log files
crash.log
crash.*.log

# Terraform plan files (may contain sensitive data)
*.tfplan
*.tfplan.json
plan.out

# Override files (used for local customisation)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
!example.tfvars
!example.tfvars.json

# Terraform CLI config
.terraformrc
terraform.rc

# ========================
# Python
# ========================

# Byte-compiled / optimised files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# mypy / pyright
.mypy_cache/
.pyright/

# ========================
# AWS / Secrets
# ========================

# AWS credentials (should never be committed)
.aws/
credentials
*.pem
*.key

# ========================
# IDE / Editor
# ========================

.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
